<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.cookshare.view.auth.SplashFragment"
        android:label="SplashFragment">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_splash_to_feed"
            app:destination="@id/feedFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.cookshare.view.auth.LoginFragment"
        android:label="LoginFragment">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_feed"
            app:destination="@id/feedFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.cookshare.view.auth.RegisterFragment"
        android:label="RegisterFragment">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.example.cookshare.view.feed.FeedFragment"
        android:label="FeedFragment">
        <action
            android:id="@+id/action_feed_to_post_detail"
            app:destination="@id/postDetailFragment" />
        <action
            android:id="@+id/action_feed_to_add_edit_post"
            app:destination="@id/addEditPostFragment" />
        <action
            android:id="@+id/action_feed_to_profile"
            app:destination="@id/userProfileFragment" />
        <action
            android:id="@+id/action_feed_to_search"
            app:destination="@id/searchFragment" />
    </fragment>

    <fragment
        android:id="@+id/postDetailFragment"
        android:name="com.example.cookshare.view.post.PostDetailFragment"
        android:label="PostDetailFragment">
        <argument
            android:name="postId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/addEditPostFragment"
        android:name="com.example.cookshare.view.post.AddEditPostFragment"
        android:label="AddEditPostFragment">
        <argument
            android:name="postId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/userProfileFragment"
        android:name="com.example.cookshare.view.profil.UserProfileFragment"
        android:label="UserProfileFragment">
        <action
            android:id="@+id/action_profile_to_my_posts"
            app:destination="@id/myPostsFragment" />
        <action
            android:id="@+id/action_profile_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/myPostsFragment"
        android:name="com.example.cookshare.view.post.MyPostsFragment"
        android:label="MyPostsFragment" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.cookshare.view.search.SearchFragment"
        android:label="SearchFragment" />

</navigation>